# Never commit real secrets. Paste local values into .env.
DEEPSEEK_API_KEY=
COMPANY_DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Only needed when building a static JOJO package that must call the company token proxy in browser.
# Keep this empty in the public repository; set it locally or in CI/Vercel environment variables.
VITE_COMPANY_DEEPSEEK_API_KEY=
VITE_COMPANY_DEEPSEEK_BASE_URL=https://token.xjjj.co/v1
VITE_COMPANY_DEEPSEEK_MODEL=deepseek-v4-flash
VITE_COMPANY_NETWORK_PROBE_URL=https://token.xjjj.co/v1/models
VITE_GITHUB_REPO_URL=https://github.com/yanghaoleng/FakeChat

# Required for voice generation/rendering. The API only uses the VoxCPM-compatible worker.
# It no longer falls back to macOS `say` or synthetic tones.
VOXCPM_WORKER_URL=

API_PORT=8787
PUBLIC_API_ORIGIN=http://127.0.0.1:8787
